    {
      "parameters": {
        "jsCode": "function contar(d) {\n  if (!d) return 0;\n  if (Array.isArray(d)) return d.length;\n  if (typeof d === 'object') {\n    if (d.quantidadeTotalElementos !== undefined) return d.quantidadeTotalElementos;\n    const k = Object.keys(d).find(x => Array.isArray(d[x]));\n    if (k) return d[k].length;\n    return d.total || d.quantidade || d.count || 0;\n  }\n  return 0;\n}\nconst ativos = $('Carteira Ativos').first().json;\nconst semTreino = $('Carteira Sem Treino').first().json;\nconst vencidos = $('Carteira Vencidos').first().json;\nconst comTreino = $('Carteira Com Treino').first().json;\nreturn [{\n  json: {\n    ativos: contar(ativos),\n    semTreino: contar(semTreino),\n    vencidos: contar(vencidos),\n    comTreino: contar(comTreino)\n  }\n}];"
      },
