{
  "name": "MOVFIT Pacto Proxy",
  "meta": {
    "templateCredsSetupCompleted": false,
    "description": "Proxy Pacto: key só nas Credentials. Front POST action=bi|professores|carteira + header X-Movfit-Proxy."
  },
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "movfit/pacto",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "wh-in",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "movfit-pacto-proxy"
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.first().json.headers || {};\nconst h = Object.fromEntries(\n  Object.entries(headers).map(([k, v]) => [String(k).toLowerCase(), v])\n);\nconst expected = $env.N8N_MOVFIT_PROXY_TOKEN || 'SUBSTITUA_TOKEN_AQUI';\nconst got = h['x-movfit-proxy'] || '';\nif (!expected || expected === 'SUBSTITUA_TOKEN_AQUI') {\n  return [{ json: { ok: false, status: 500, error: 'Configure N8N_MOVFIT_PROXY_TOKEN no n8n (ou edite este nó).' } }];\n}\nif (got !== expected) {\n  return [{ json: { ok: false, status: 401, error: 'Unauthorized' } }];\n}\nconst body = $input.first().json.body || $input.first().json;\nconst action = String(body.action || '').toLowerCase();\nconst empresaId = String(body.empresaId || '1');\nconst codigoPessoa = body.codigoPessoa != null ? String(body.codigoPessoa) : '';\nif (!['bi', 'professores', 'carteira'].includes(action)) {\n  return [{ json: { ok: false, status: 400, error: 'action deve ser bi | professores | carteira' } }];\n}\nif (action === 'carteira' && !codigoPessoa) {\n  return [{ json: { ok: false, status: 400, error: 'codigoPessoa obrigatório para carteira' } }];\n}\nreturn [{ json: { ok: true, action, empresaId, codigoPessoa } }];"
      },
      "id": "check-token",
      "name": "Check proxy token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.ok }}",
              "value2": true
            }
          ]
        }
      },
      "id": "if-auth",
      "name": "Auth OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [480, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { error: $json.error || 'Unauthorized' } }}",
        "options": {
          "responseCode": "={{ $json.status || 401 }}"
        }
      },
      "id": "resp-err",
      "name": "Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [720, 480]
    },
